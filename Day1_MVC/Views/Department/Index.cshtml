@model IEnumerable<Department>
@{
    ViewData["Title"] = "Index";
}

<link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet" />


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-secondary">Department List</h2>
        <a asp-action="Create" asp-controller="Department" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add New Department
        </a>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-bordered">
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>StudentCount</th>
                    <th>Courses</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model)
                {
                    <tr>
                        <td>@dept.Id</td>
                        <td class="fw-bold">@dept.Name</td>
                        <td>@dept.StudentCount</td>
                        <td>
                            <form asp-action="Grades"
                                  asp-controller="Department"
                                 
                                  method="get"
                                  class="d-flex gap-1">
                                <input type="hidden" name="deptid" value="@dept.Id" />
                                <select name="crsid" class="form-select form-select-sm">
                                    @foreach (var crs in dept.Courses)
                                    {
                                        <option value="@crs.Id">@crs.Name</option>
                                    }
                                </select>

                                <button type="submit"
                                        class="btn btn-sm btn-outline-secondary">
                                    Go
                                </button>
                            </form>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit"
                               asp-controller="Department"
                               asp-route-id="@dept.Id"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Delete"
                               asp-controller="Department"
                               asp-route-id="@dept.Id"
                               class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>


                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

