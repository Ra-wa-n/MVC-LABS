@model Department

@{
    ViewData["Title"] = "Edit";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow-sm p-4 border rounded bg-light">
            <h2 class="text-primary mb-4">Edit Department</h2>

            <form asp-action="Edit" asp-controller="Department" method="post">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label font-weight-bold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StudentCount" class="form-label font-weight-bold"></label>
                    <input asp-for="StudentCount" type="number" class="form-control" />
                    <span asp-validation-for="StudentCount" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Select Courses to Remove</label>
                    <select name="coursestoremove" class="form-control" multiple size="5">
                        @foreach (var item in Model.Courses)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Select Courses to Add</label>
                    <select name="coursestoadd" class="form-control" multiple size="5">
                        @foreach (var item in ViewBag.crsnotinpept)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>
               

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>