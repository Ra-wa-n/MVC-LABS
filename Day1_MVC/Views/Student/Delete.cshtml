@model Student

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Confirm Deletion</h3>
        </div>
        <div class="card-body">
            <p class="lead text-center">Are you sure you want to delete this student?</p>
            <hr />
            <dl class="row">
                <dt class="col-sm-3 text-muted">ID:</dt>
                <dd class="col-sm-9 fw-bold">@Model.Id</dd>

                <dt class="col-sm-3 text-muted">Name:</dt>
                <dd class="col-sm-9 fw-bold">@Model.Name</dd>

                <dt class="col-sm-3 text-muted">Age:</dt>
                <dd class="col-sm-9">@Model.Age</dd>

                <dt class="col-sm-3 text-muted">Email:</dt>
                <dd class="col-sm-9">@Model.Email</dd>
            </dl>
        </div>
        <div class="card-footer bg-light d-flex justify-content-end gap-2">
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i>  Delete
                </button>
            </form>
            <a asp-action="DisplayStudents" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</div>