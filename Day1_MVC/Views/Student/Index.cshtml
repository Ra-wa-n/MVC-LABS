@model Student

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Student Profile</h5>
                </div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.Name</p>
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Age:</strong> @Model.Age</p>
                    <p><strong>Department:</strong> @(Model.Department?.Name ?? "N/A")</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">My Enrolled Courses</h5>
                    <span class="badge bg-info">@Model.Department?.Name Only</span>
                </div>
                <div class="card-body">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Course Name</th>
                                <th class="text-center">Grade</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var gradesList = ViewBag.grades as List<StudentCourse>;
                            }

                            @if (gradesList != null && gradesList.Any())
                            {
                                foreach (var item in gradesList)
                                {
                                    <tr>
                                        <td><strong>@item.Course.Name</strong></td>
                                        <td class="text-center">
                                            @if (item.Degree.HasValue)
                                            {
                                                <span class="fw-bold">@item.Degree</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted italic">Pending</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!item.Degree.HasValue)
                                            {
                                                <span class="badge bg-secondary">In Progress</span>
                                            }
                                            else if (item.Degree >= 50)
                                            {
                                                <span class="badge bg-success">Passed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Failed</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">
                                        No courses found for your department.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>