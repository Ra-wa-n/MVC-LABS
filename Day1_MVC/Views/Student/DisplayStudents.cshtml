
@model IEnumerable<Student> 



<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-secondary">Student List</h2>
        <a asp-action="Create" asp-controller="Student" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add New Student
        </a>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-bordered">
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Email</th>
                    <th>Depatrment</th>
                    <th>Courses</th>

                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model) 
                {
                    <tr>
                        <td>@student.Id</td>
                        <td class="fw-bold">@(student?.Name ?? "N/A")</td>
                        <td>@(student?.Age != null ? student.Age.ToString() : "N/A")</td>
                        <td>@(student?.Email ?? "N/A")</td>

                      
                        <td>@(student?.Department?.Name ?? "No Department")</td>

                        <td>
                            @{
                                var coursesMap = ViewBag.StudentCoursesMap as Dictionary<int, List<Course>>;
                                // Try to get the list; if map is null or key missing, default to an empty list.
                                var studentCourses = coursesMap?.GetValueOrDefault(student.Id) ?? new List<Course>();
                            }

                            <select class="form-select form-select-sm">
                                @if (studentCourses.Any())
                                {
                                    foreach (var crs in studentCourses)
                                    {
                                        <option value="@crs.Id">@crs.Name</option>
                                    }
                                }
                                else
                                {
                                    <option disabled selected>No Courses Assigned</option>
                                }
                            </select>
                        </td>

                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-controller="Student" asp-route-id="@student.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-controller="Student" asp-route-id="@student.Id" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>